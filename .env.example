# banner-studio-site 環境變數範例
#
# 複製本檔為 .env.local,填入實際值
# 注意:.env.local 已在 .gitignore,不可推上 git

# === Google Chat Webhook(即時通知 Kay 有新申請)===
# 從 Banner Agent 既有的 Chat webhook 複製過來即可
CHAT_WEBHOOK=

# === Google Sheets Webhook(累積申請紀錄,考績佐證)===
# 從 Google Sheet → Extensions → Apps Script → Deploy as Web app 拿到
# 詳細步驟見 docs/banner-studio-full-copy-and-spec.md §資料持久化架構
SHEETS_WEBHOOK_URL=
